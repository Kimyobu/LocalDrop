{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./out",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "src/renderer/src/**/*",
    "../shared/**/*"
  ]
}
